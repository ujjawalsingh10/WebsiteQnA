{
    "_comment" : "Web Crawler Configuration",
    "seeds" : [
        "https://pmjay.gov.in/"
    ],
    "crawl" : {
        "max_depth" : 3,
        "max_pages" : 700,
        "max_pages_per_domain" : 500,
        "delay_between_requests_sec" : 1.5,
        "request_timeout_sec" : 20,
        "max_retries" : 3,
        "concurrent_requests" : 3,
        "respect_robots_txt" : true,
        "user_agent" : "RAGBot/1.0 (Crawler; @cdac,noida"
    },
    "scope" : {
        "internal_only": true,
        "allow_subdomains" : true,
        "external_sittes_whitelist" : [],
        "url_patterns_include" : [],
        "url_patterns_exclude" : [
         ".*\\.(css|js|woff|woff2|ttf|eot|ico|svg)$",
        ".*/login.*",
        ".*/logout.*",
        ".*/cart.*",
        ".*/account.*",
        ".*\\?.*sessionid.*",
        ".*\\?.*token.*"
        ]
    },
    "assets" : {
        "download_images" : true,
        "download_pdfs" : true,
        "min_image_size_bytes" : 5120,
        "max_image_size_mb" : 20,
        "max_pdf_size_mb" : 100,
        "image_extensions" : [
            ".jpg",
            ".jpeg",
            ".png",
            ".webp",
            ".gif",
            ".bmp"
        ],
        "pdf_extensions" : [
            ".pdf"
        ]
    },
    "extraction": {
        "preserve_heading_hierarchy": true,
        "extract_tables": true,
        "extract_meta_tags" : true,
        "min_text_length_chars" : 100,
        "_comment_noise_selectors": "CSS selectors to decompose before markdown conversion. Add site-specific selectors here.",
        "noise_selectors": [
            ".topbar",
            ".footer_logos",
            ".pager",
            ".pagination",
            "nav.pager",
            ".view-id-photo_gallery",
            ".view-id-video_gallery", 
            ".field--name-field-youtube-video",
            ".views-field-field-youtube-video",
            ".twitter-timeline",
            ".fb-page",
            "[class*='social']",
            ".counter-section",
            ".stats-section",
            "#block-views-block-social-media-feeds",
            ".ayushman-diaries",
            ".footer_logos",
            "#cookie-banner",
            ".sticky-header",
            ".social-share",
            ".related-links",
            ".advertisement"
        ],
        "_comment_skip_link_prefixes": "Anchor link text starting with these strings will be removed (skip-to-content links)",
        "skip_link_prefixes": [
        "skip",
        "jump to",
        "go to main"
        ]
    },
    "output" : {
        "base_dir" : "./output",
        "pretty_json" : true,
        "compress_old_runs": false
    },
    "logging" : {
        "level" : "INFO",
        "log_file" : "./output/crawl.log",
        "progress_every_n_pages" : 10
    }

}